{
  "id": "molt-gic-openclaw-extension",
  "name": "molt-gic OpenClaw Extension",
  "description": "Registers bounded gateway HTTP and RPC smoke surfaces for molt-gic live receipts.",
  "kind": "utility",
  "version": "0.3.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "routePath": {
        "type": "string",
        "default": "/molt-gic/hook"
      }
    }
  }
}
