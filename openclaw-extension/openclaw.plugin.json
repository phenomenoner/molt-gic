{
  "id": "molt-gic-openclaw-extension",
  "name": "molt-gic OpenClaw Extension",
  "description": "Bounded OpenClaw HTTP/RPC/command bridge with passive autonomy digest for molt-gic.",
  "kind": "utility",
  "version": "0.4.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "routePath": {
        "type": "string",
        "default": "/molt-gic/hook"
      },
      "autonomyDigest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "path": {
            "type": "string",
            "default": "memory/molt-gic-autonomy-digest.json"
          },
          "promptContextEnabled": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "enableEvolveApplyCommands": {
        "type": "boolean",
        "default": true
      }
    }
  }
}
